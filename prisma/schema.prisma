// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int     @id @default(autoincrement())
  name        String? @db.VarChar(255)
  username    String  @db.VarChar(255)
  email       String  @unique @db.VarChar(255)
  password    String  @db.VarChar(255)
  accountType String  @db.VarChar(50)
  avatar      String? @db.VarChar(255)
  role_id     Int
  role        Role    @relation(fields: [role_id], references: [id])
  videos      Video[]
  analysisSessions AnalysisSession[]

  @@map("users")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(4)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(100)
  users User[]

  @@map("roles")
}

model Video {
  id           Int           @id @default(autoincrement())
  input_video  String?       @db.VarChar(255)
  recognition_list_path String? @db.VarChar(512)
  output_video String?       @db.VarChar(255)
  status       String?       @db.VarChar(255)
  videoPlayers VideoPlayer[]
  createdAt               DateTime @default(now())
  user_id      Int
  user         User          @relation(fields: [user_id], references: [id])
  analysis_session_id Int?
  analysisSession AnalysisSession? @relation(fields: [analysis_session_id], references: [id])

  @@map("videos")
}

model AnalysisSession {
  id        Int      @id @default(autoincrement())
  team_a    String   @db.VarChar(255)
  team_b    String   @db.VarChar(255)
  createdAt DateTime @default(now())

  user_id   Int
  user      User     @relation(fields: [user_id], references: [id])

  players   AnalysisSessionPlayer[]
  videos    Video[]

  @@index([user_id])
  @@map("analysis_sessions")
}

model Player {
  id           Int           @id @default(autoincrement())
  shirt_number Int?
  player_name  String?       @db.VarChar(255)
  team         String?       @db.VarChar(255)
  position     String?       @db.VarChar(255)
  videoPlayers VideoPlayer[]
  analysisSessions AnalysisSessionPlayer[]

  @@map("players")
}

model AnalysisSessionPlayer {
  id         Int            @id @default(autoincrement())
  session_id Int
  session    AnalysisSession @relation(fields: [session_id], references: [id])
  player_id  Int
  player     Player         @relation(fields: [player_id], references: [id])

  @@unique([session_id, player_id])
  @@index([session_id])
  @@index([player_id])
  @@map("analysis_session_players")
}

model VideoPlayer {
  id        Int    @id @default(autoincrement())
  video_id  Int
  video     Video  @relation(fields: [video_id], references: [id])
  player_id Int
  player    Player @relation(fields: [player_id], references: [id])

  @@map("video_players")
}
