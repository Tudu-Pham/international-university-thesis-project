<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In — Football Analytics</title>
    <link rel="icon" type="image/png" href="images/logo.ico">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-signin">
    <div class="signin-bg" aria-hidden="true"></div>

    <main class="signin-main">
        <div class="signin-card glass-card">
            <header class="signin-brand">
                <div class="brand-logo">
                    <img class="brand-logo__img" src="/images/logo.png" width="56" height="56" alt="Football Analytics">
                </div>
                <div class="brand-text">
                    <span class="brand-text__football">FOOTBALL</span>
                    <span class="brand-text__analytics">ANALYTICS</span>
                </div>
            </header>

            <h1 class="signin-heading">SIGN IN</h1>

            <form class="signin-form" action="#" method="post" novalidate>
                <label class="field-label visually-hidden" for="signin-email">Email</label>
                <div class="input-wrap">
                    <span class="input-wrap__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.75">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </span>
                    <input class="signin-input" type="email" id="signin-email" name="email" placeholder="Email"
                        autocomplete="email" required>
                </div>

                <label class="field-label visually-hidden" for="signin-password">Password</label>
                <div class="input-wrap">
                    <span class="input-wrap__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.75">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input class="signin-input signin-input--password" type="password" id="signin-password"
                        name="password" placeholder="Password" autocomplete="current-password" required>
                    <button type="button" class="input-wrap__toggle" id="toggle-password" aria-label="Show password"
                        aria-pressed="false">
                        <svg class="icon-eye icon-eye--open" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="1.75">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="icon-eye icon-eye--closed" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="1.75" hidden>
                            <path
                                d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>

                <div class="signin-options">
                    <label class="remember">
                        <input class="remember__input" type="checkbox" name="remember" checked>
                        <span class="remember__box" aria-hidden="true"></span>
                        <span class="remember__label">Remember me</span>
                    </label>
                    <a href="#" class="link-muted">Forgot password?</a>
                </div>

                <button type="submit" class="btn-signin">Sign In</button>
            </form>

            <p class="signin-footer-prompt">
                <span class="text-muted-prompt">Don't have an account?</span>
                <a href="/createUser" class="link-signup">Sign up</a>
            </p>
        </div>
    </main>

    <footer class="signin-page-footer">
        <p class="signin-page-footer__copy">&copy; 2026 Football Analytics. All rights reserved.</p>
    </footer>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>