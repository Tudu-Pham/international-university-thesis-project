<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot password — Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-signin">
    <div class="signin-bg" aria-hidden="true"></div>

    <main class="signin-main">
        <div class="signin-card glass-card">
            <header class="signin-brand">
                <div class="brand-logo">
                    <img class="brand-logo__img" src="/images/logo.png" width="56" height="56" alt="Football Analytics">
                </div>
                <a href="/" class="simple-link">
                    <div class="brand-text">
                        <span class="brand-text__football">FOOTBALL</span>
                        <span class="brand-text__analytics">ANALYTICS</span>
                    </div>
                </a>
            </header>

            <h1 class="signin-heading">Forgot password</h1>

            <% if (typeof error !=='undefined' && error) { %>
                <p class="text-danger mb-3" role="alert">
                    <%= error %>
                </p>
                <% } %>
                    <% if (typeof info !=='undefined' && info) { %>
                        <p class="text-success mb-3" role="status">
                            <%= info %>
                        </p>
                        <% } %>

                            <form class="signin-form" action="/forgot-password" method="post" novalidate>
                                <label class="field-label visually-hidden" for="fp-email">Email</label>
                                <div class="input-wrap">
                                    <span class="input-wrap__icon" aria-hidden="true">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="1.75">
                                            <rect x="3" y="5" width="18" height="14" rx="2" ry="2" />
                                            <path d="M3 7l9 6 9-6" />
                                        </svg>
                                    </span>
                                    <input class="signin-input" type="email" id="fp-email" name="email"
                                        placeholder="Email" autocomplete="email" required>
                                </div>

                                <button type="submit" class="btn-signin">Send code</button>
                            </form>

                            <p class="signin-footer-prompt mt-3">
                                <a href="/signin" class="link-signup">Back to sign in</a>
                            </p>
        </div>
    </main>

    <footer class="signin-page-footer">
        <p class="signin-page-footer__copy">&copy; 2026 Football Analytics. All rights reserved.</p>
    </footer>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>