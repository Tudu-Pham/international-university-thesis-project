<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enter code — Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-signin">
    <div class="signin-bg" aria-hidden="true"></div>

    <main class="signin-main">
        <div class="signin-card glass-card">
            <header class="signin-brand">
                <div class="brand-logo">
                    <img class="brand-logo__img" src="/images/logo.png" width="56" height="56" alt="Football Analytics">
                </div>
                <a href="/" class="simple-link">
                    <div class="brand-text">
                        <span class="brand-text__football">FOOTBALL</span>
                        <span class="brand-text__analytics">ANALYTICS</span>
                    </div>
                </a>
            </header>

            <h1 class="signin-heading" id="fp-verify-title">Verification code</h1>

            <% if (typeof error !=='undefined' && error) { %>
                <p class="text-danger mb-3" role="alert">
                    <%= error %>
                </p>
                <% } %>

                    <p class="otp-instruction" id="fp-verify-desc">
                        Enter the code sent to
                        <strong class="otp-email"><%= typeof email !== 'undefined' ? email : '' %></strong>
                    </p>

                    <form class="signin-form" action="/forgot-password/code" method="post" novalidate
                        data-otp-form>
                        <input type="hidden" name="code" id="fp-code" value="" autocomplete="off">

                        <div class="otp-group" role="group" aria-labelledby="fp-verify-title"
                            aria-describedby="fp-verify-desc">
                            <input class="otp-cell" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1"
                                data-otp-digit="0" autocomplete="one-time-code" aria-label="Digit 1 of 4">
                            <input class="otp-cell" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1"
                                data-otp-digit="1" autocomplete="off" aria-label="Digit 2 of 4">
                            <input class="otp-cell" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1"
                                data-otp-digit="2" autocomplete="off" aria-label="Digit 3 of 4">
                            <input class="otp-cell" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1"
                                data-otp-digit="3" autocomplete="off" aria-label="Digit 4 of 4">
                        </div>

                        <button type="submit" class="btn-signin">Reset password</button>
                    </form>

                    <p class="signin-footer-prompt mt-3">
                        <a href="/forgot-password" class="link-signup">Use a different email</a>
                        &nbsp;·&nbsp;
                        <a href="/signin" class="link-signup">Back to sign in</a>
                    </p>
        </div>
    </main>

    <footer class="signin-page-footer">
        <p class="signin-page-footer__copy">&copy; 2026 Football Analytics. All rights reserved.</p>
    </footer>

    <script src="/javascripts/main.js" defer></script>
    <script src="/javascripts/forgot-password-code.js" defer></script>
</body>

</html>