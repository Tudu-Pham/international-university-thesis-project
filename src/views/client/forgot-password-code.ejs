<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enter code — Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-signin">
    <div class="signin-bg" aria-hidden="true"></div>

    <main class="signin-main">
        <div class="signin-card glass-card">
            <header class="signin-brand">
                <div class="brand-logo">
                    <img class="brand-logo__img" src="/images/logo.png" width="56" height="56" alt="Football Analytics">
                </div>
                <a href="/" class="simple-link">
                    <div class="brand-text">
                        <span class="brand-text__football">FOOTBALL</span>
                        <span class="brand-text__analytics">ANALYTICS</span>
                    </div>
                </a>
            </header>

            <h1 class="signin-heading">Verification code</h1>

            <% if (typeof error !=='undefined' && error) { %>
                <p class="text-danger mb-3" role="alert">
                    <%= error %>
                </p>
                <% } %>

                    <form class="signin-form" action="/forgot-password/code" method="post" novalidate>
                        <label class="field-label visually-hidden" for="fp-code">Code</label>
                        <div class="input-wrap">
                            <span class="input-wrap__icon" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.75">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            </span>
                            <input class="signin-input" type="text" id="fp-code" name="code" placeholder="4-digit code"
                                inputmode="numeric" pattern="[0-9]{4}" maxlength="4" autocomplete="one-time-code"
                                required>
                        </div>

                        <button type="submit" class="btn-signin">Reset password</button>
                    </form>

                    <p class="signin-footer-prompt mt-3">
                        <a href="/forgot-password" class="link-signup">Use a different email</a>
                        &nbsp;·&nbsp;
                        <a href="/signin" class="link-signup">Back to sign in</a>
                    </p>
        </div>
    </main>

    <footer class="signin-page-footer">
        <p class="signin-page-footer__copy">&copy; 2026 Football Analytics. All rights reserved.</p>
    </footer>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>