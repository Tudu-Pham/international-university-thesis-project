<!DOCTYPE html>
<html lang="en" class="home-root">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-home">
    <header class="home-nav" role="banner">
        <div class="home-nav__inner">
            <a>
            </a>
            <nav class="home-nav__actions" aria-label="Primary">
                <a class="home-nav__link home-nav__link--cta" href="#features">Get Started</a>
                <a class="home-nav__link home-nav__link--ghost" href="/signin">Log in</a>
            </nav>
        </div>
    </header>

    <main class="home-main">
        <section class="home-hero" id="top" aria-labelledby="home-hero-heading">
            <div class="home-hero__bg" data-home-parallax-bg="hero" aria-hidden="true"></div>
            <div class="home-hero__veil" aria-hidden="true"></div>

            <div class="home-hero__grid">
                <div class="home-hero__copy">
                    <h1 id="home-hero-heading" class="home-hero__title">
                        Elevate Your Game with Advanced Football <span class="home-hero__accent">Analytics</span>
                    </h1>
                    <p class="home-hero__lead">
                        Analyze matches, generate insights, and take performance to the next level with cutting-edge
                        technology.
                    </p>
                    <a class="home-btn home-btn--large" href="#features">Get Started</a>
                </div>

                <div class="home-hero__visual" data-home-parallax="0.04">
                    <div class="home-hud home-hud--left" aria-hidden="true">
                        <div class="home-hud__bars">
                            <span></span><span></span><span></span><span></span>
                        </div>
                        <div class="home-hud__nodes"></div>
                    </div>
                    <div class="home-laptop">
                        <div class="home-laptop__glow" aria-hidden="true"></div>
                        <div class="home-laptop__shell">
                            <div class="home-laptop__screen">
                                <img src="/images/home_latop_screen.png" alt="" class="home-laptop__img" width="640"
                                    height="400">
                            </div>
                            <div class="home-laptop__base" aria-hidden="true"></div>
                        </div>
                    </div>
                    <div class="home-hud home-hud--right" aria-hidden="true">
                        <div class="home-hud__mini-chart"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="home-features" id="features" aria-labelledby="home-features-heading">
            <div class="home-features__bg" data-home-parallax-bg="features" aria-hidden="true"></div>
            <div class="home-features__veil" aria-hidden="true"></div>

            <div class="home-features__inner">
                <h2 id="home-features-heading" class="home-features__title">Key Features</h2>
                <div class="home-features__cards">
                    <article class="home-card">
                        <div class="home-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"
                                class="home-card__svg">
                                <rect x="6" y="18" width="26" height="18" rx="2" stroke="currentColor"
                                    stroke-width="2" />
                                <circle cx="31" cy="17" r="7" stroke="currentColor" stroke-width="2" />
                                <path d="M36 22l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            </svg>
                        </div>
                        <h3 class="home-card__title">Match Analysis</h3>
                        <p class="home-card__text">In-depth analysis of matches with detailed statistics</p>
                    </article>
                    <article class="home-card">
                        <div class="home-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"
                                class="home-card__svg">
                                <rect x="10" y="10" width="28" height="28" rx="4" stroke="currentColor"
                                    stroke-width="2" />
                                <path d="M24 16l2.5 6.5H33l-5.5 4 2 7L24 29l-5.5 4.5 2-7L15 22.5h6.5L24 16z"
                                    fill="currentColor" opacity="0.9" />
                            </svg>
                        </div>
                        <h3 class="home-card__title">AI Highlights</h3>
                        <p class="home-card__text">Automated highlight generation powered by AI</p>
                    </article>
                    <article class="home-card">
                        <div class="home-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"
                                class="home-card__svg">
                                <circle cx="24" cy="14" r="5" stroke="currentColor" stroke-width="2" />
                                <path d="M14 38c0-8 4.5-12 10-12s10 4 10 12" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" />
                            </svg>
                        </div>
                        <h3 class="home-card__title">Player Performance</h3>
                        <p class="home-card__text">Track and evaluate player performance</p>
                    </article>
                </div>
            </div>
        </section>
    </main>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>