                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <footer class="fa-prof-pagination" aria-label="Pagination">
                        <span class="fa-prof-pagination__info">Showing 1–6 of 24 results</span>
                        <nav class="fa-prof-pagination__nav" aria-label="Page">
                            <button type="button" class="fa-prof-page-btn" aria-label="Previous page"
                                disabled>&lsaquo;</button>
                            <button type="button" class="fa-prof-page-btn fa-prof-page-btn--active"
                                aria-current="page">1</button>
                            <button type="button" class="fa-prof-page-btn">2</button>
                            <button type="button" class="fa-prof-page-btn">3</button>
                            <button type="button" class="fa-prof-page-btn">4</button>
                            <button type="button" class="fa-prof-page-btn" aria-label="Next page">&rsaquo;</button>
                        </nav>
                        <div class="fa-prof-rows">
                            <label for="fa-prof-rows-select">Rows per page:</label>
                            <select id="fa-prof-rows-select" class="fa-prof-rows__select" aria-label="Rows per page">
                                <option>10</option>
                                <option>25</option>
                                <option>50</option>
                            </select>
                        </div>
                    </footer>
                </main>
            </div>
        </div>
    </div>

    <div class="fa-prof-modal" id="fa-prof-update-modal" hidden aria-hidden="true">
        <div class="fa-prof-modal__backdrop" data-fa-prof-close-modal tabindex="-1"></div>
        <div class="fa-prof-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="fa-prof-modal-title"
            tabindex="-1">
            <div class="fa-prof-modal__head">
                <h2 id="fa-prof-modal-title" class="fa-prof-modal__title">Update profile</h2>
                <button type="button" class="fa-prof-modal__close" data-fa-prof-close-modal
                    aria-label="Close">&times;</button>
            </div>
            <form class="fa-prof-modal__form" id="fa-prof-update-form" novalidate>
                <p class="fa-prof-modal__hint">Only fill in the fields you want to change — all fields are optional.</p>
                <div class="fa-field">
                    <label class="fa-field__label" for="fa-prof-up-avatar">Avatar</label>
                    <input class="fa-field__input fa-prof-modal__file" type="file" id="fa-prof-up-avatar" name="avatar"
                        accept="image/*">
                </div>
                <div class="fa-field">
                    <label class="fa-field__label" for="fa-prof-up-name">Name</label>
                    <input class="fa-field__input" type="text" id="fa-prof-up-name" name="name" placeholder="Full name"
                        autocomplete="name">
                </div>
                <div class="fa-field">
                    <label class="fa-field__label" for="fa-prof-up-username">Username</label>
                    <input class="fa-field__input" type="text" id="fa-prof-up-username" name="username"
                        placeholder="username" autocomplete="username">
                </div>
                <div class="fa-field">
                    <label class="fa-field__label" for="fa-prof-up-oldpw">Old password</label>
                    <input class="fa-field__input" type="password" id="fa-prof-up-oldpw" name="oldPassword"
                        placeholder="••••••••" autocomplete="current-password">
                </div>
                <div class="fa-field">
                    <label class="fa-field__label" for="fa-prof-up-newpw">New password</label>
                    <input class="fa-field__input" type="password" id="fa-prof-up-newpw" name="newPassword"
                        placeholder="••••••••" autocomplete="new-password">
                </div>
                <button type="submit" class="fa-btn-primary fa-btn-primary--block fa-prof-modal__submit">Update</button>
            </form>
        </div>
    </div>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>