<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile — Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        $(document).ready(() => {
            const avatarFile = $("#avatarFile");
            const avatarPreview = $("#avatarPreview");
            let avatarBlobUrl = null;
            avatarFile.change(function (e) {
                const file = e.target.files && e.target.files[0];
                if (!file) return;
                if (avatarBlobUrl) URL.revokeObjectURL(avatarBlobUrl);
                avatarBlobUrl = URL.createObjectURL(file);
                avatarPreview.attr("src", avatarBlobUrl);
                avatarPreview.css({ "display": "block" });
            });
            $("#fa-prof-update-form").on("reset", function () {
                if (avatarBlobUrl) {
                    URL.revokeObjectURL(avatarBlobUrl);
                    avatarBlobUrl = null;
                }
                avatarPreview.attr("src", "").css({ "display": "none" });
            });
        });
    </script>
</head>

<body class="page-fa-analyze page-fa-profile" <% if (typeof openProfileModal !=='undefined' && openProfileModal) { %>
    data-fa-prof-open-modal="1"<% } %>>
        <div class="fa-analyze__bg" aria-hidden="true"></div>
        <div class="fa-analyze__veil" aria-hidden="true"></div>

        <div class="fa-shell">
            <aside class="fa-sidebar" aria-label="Main navigation">
                <a class="fa-sidebar__link" href="/football-analytics" title="Analytics">
                    <svg class="fa-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                </a>
                <a class="fa-sidebar__link fa-sidebar__link--active" href="/profile" title="Profile"
                    aria-current="page">
                    <svg class="fa-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </a>
                <a class="fa-sidebar__link" href="/" title="Exit">
                    <svg class="fa-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </a>
            </aside>

            <div class="fa-workspace">
                <header class="fa-topbar" role="banner">
                    <div class="fa-topbar__brand">
                        <img src="/images/logo.png" alt="" class="fa-topbar__logo" width="44" height="44">
                        <a href="/" class="simple-link">
                            <div class="fa-topbar__brand-text">
                                <span class="fa-topbar__brand-football">FOOTBALL</span>
                                <span class="fa-topbar__brand-analytics">ANALYTICS</span>
                            </div>
                        </a>
                    </div>
                    <div class="fa-topbar__user">
                        <div class="fa-user-chip">
                            <span class="fa-user-chip__avatar" aria-hidden="true">
                                <img src="<%= currentUser && currentUser.avatar ? currentUser.avatar : '/images/default_avatar.jpg' %>"
                                    alt="">
                            </span>
                            <span class="fa-user-chip__name">
                                <%= currentUser && currentUser.name ? currentUser.name : '' %>
                            </span>
                        </div>
                        <a href="/logout" class="fa-btn-logout fa-btn-logout--link">Log out</a>
                    </div>
                </header>

                <% if (typeof profileSuccess !=='undefined' && profileSuccess) { %>
                    <div class="fa-prof-flash fa-prof-flash--success" role="status">Profile updated successfully.</div>
                    <% } %>
                        <% if (typeof profileErrorMessage !=='undefined' && profileErrorMessage) { %>
                            <div class="fa-prof-flash fa-prof-flash--error" role="alert">
                                <%= profileErrorMessage %>
                            </div>
                            <% } %>

                                <div class="fa-prof-layout">
                                    <aside class="fa-prof-aside" aria-label="Profile information">
                                        <div class="fa-prof-avatar-ring">
                                            <img src="<%= currentUser && currentUser.avatar ? currentUser.avatar : '/images/default_avatar.jpg' %>"
                                                alt="" class="fa-prof-avatar" width="120" height="120">
                                        </div>
                                        <h1 class="fa-prof-name">
                                            <%= typeof displayName !=='undefined' ? displayName : '' %>
                                        </h1>
                                        <p class="fa-prof-handle">@<%= profileUser && profileUser.username ?
                                                profileUser.username : '' %>
                                        </p>

                                        <div class="fa-prof-info-card">
                                            <span class="fa-prof-info-card__icon" aria-hidden="true">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                                    <circle cx="12" cy="7" r="4" />
                                                </svg>
                                            </span>
                                            <div class="fa-prof-info-card__body">
                                                <span class="fa-prof-info-card__label">Username</span>
                                                <span class="fa-prof-info-card__value">
                                                    <%= profileUser && profileUser.username ? profileUser.username : '—'
                                                        %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="fa-prof-info-card">
                                            <span class="fa-prof-info-card__icon" aria-hidden="true">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                                    <polyline points="22,6 12,13 2,6" />
                                                </svg>
                                            </span>
                                            <div class="fa-prof-info-card__body">
                                                <span class="fa-prof-info-card__label">Email</span>
                                                <span class="fa-prof-info-card__value">
                                                    <%= profileUser && profileUser.email ? profileUser.email : '—' %>
                                                </span>
                                            </div>
                                        </div>

                                        <button type="button" class="fa-prof-btn-update" data-fa-prof-open-update>Update
                                            profile</button>
                                    </aside>

                                    <main class="fa-prof-main">
                                        <header class="fa-prof-main__head">
                                            <div>
                                                <h2 class="fa-prof-main__title">My analyzed clips</h2>
                                                <p class="fa-prof-main__subtitle">Manage and view all your analyzed
                                                    football match clips.
                                                </p>
                                            </div>
                                        </header>

                                        <div class="fa-prof-toolbar">
                                            <div class="fa-prof-search">
                                                <svg class="fa-prof-search__icon" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                    <circle cx="11" cy="11" r="8" />
                                                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                                </svg>
                                                <input type="search" class="fa-prof-search__input"
                                                    id="fa-prof-clips-search" placeholder="Search by team, date..."
                                                    aria-label="Search clips">
                                            </div>
                                            <div class="fa-prof-filter" data-fa-prof-filter>
                                                <span class="fa-prof-filter__icon" aria-hidden="true">
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                                                    </svg>
                                                </span>
                                                <div class="fa-prof-filter__wrap">
                                                    <span id="fa-prof-filter-sort-label" class="visually-hidden">Sort
                                                        clips by date</span>
                                                    <button type="button" class="fa-prof-filter__trigger"
                                                        id="fa-prof-filter-trigger" aria-haspopup="listbox"
                                                        aria-expanded="false" aria-controls="fa-prof-filter-list"
                                                        aria-labelledby="fa-prof-filter-sort-label fa-prof-filter-current">
                                                        <span class="fa-prof-filter__current"
                                                            id="fa-prof-filter-current">Newest to
                                                            oldest</span>
                                                        <span class="fa-prof-filter__chev" aria-hidden="true">
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path d="M6 9l6 6 6-6" />
                                                            </svg>
                                                        </span>
                                                    </button>
                                                    <ul class="fa-prof-filter__list" id="fa-prof-filter-list"
                                                        role="listbox" tabindex="-1" hidden>
                                                        <li class="fa-prof-filter__option fa-prof-filter__option--active"
                                                            role="option" data-value="newest" aria-selected="true">
                                                            Newest to oldest</li>
                                                        <li class="fa-prof-filter__option" role="option"
                                                            data-value="oldest" aria-selected="false">Oldest to newest
                                                        </li>
                                                    </ul>
                                                    <input type="hidden" id="fa-prof-filter-sort" name="clipSort"
                                                        value="newest" aria-hidden="true">
                                                </div>
                                            </div>
                                        </div>

                                        <div class="fa-table-wrap fa-prof-table-wrap">
                                            <table class="fa-table fa-prof-clips-table">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Team A</th>
                                                        <th>Team B</th>
                                                        <th>Input video</th>
                                                        <th>Output video</th>
                                                        <th>Date</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="fa-prof-clips-tbody">
                                                    <%
                                                    function clipNameFromPath(p) {
                                                        if (!p) return "—";
                                                        var s = String(p);
                                                        // strip query/hash (if any)
                                                        s = s.split("?")[0].split("#")[0];
                                                        // handle both URL and Windows paths
                                                        s = s.replace(/\\/g, "/");
                                                        var parts = s.split("/");
                                                        return parts[parts.length - 1] || "—";
                                                    }
                                                    %>

                                                    <% if (typeof clips !== 'undefined' && clips && clips.length) { %>
                                                        <% clips.forEach(function(clip, idx) { %>
                                                            <tr data-fa-prof-date="<%= clip.created_at ? new Date(clip.created_at).getTime() : 0 %>">
                                                                <td><%= idx + 1 %></td>
                                                                <td><%= clip.team_a ? clip.team_a : '—' %></td>
                                                                <td><%= clip.team_b ? clip.team_b : '—' %></td>
                                                                <td>
                                                                    <div class="fa-prof-vid-cell">
                                                                        <span class="fa-prof-vid-thumb" aria-hidden="true">
                                                                            <span class="fa-prof-vid-play"></span>
                                                                        </span>
                                                                        <span class="fa-prof-vid-meta">
                                                                            <span class="fa-prof-vid-name"><%= clipNameFromPath(clip.input_video) %></span>
                                                                            <span class="fa-prof-vid-size">
                                                                                <%= (clip.input_size_mb != null && isFinite(clip.input_size_mb)) ? (Number(clip.input_size_mb).toFixed(1) + " MB") : "—" %>
                                                                            </span>
                                                                        </span>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="fa-prof-vid-cell">
                                                                        <span class="fa-prof-vid-thumb" aria-hidden="true">
                                                                            <span class="fa-prof-vid-play"></span>
                                                                        </span>
                                                                        <span class="fa-prof-vid-meta">
                                                                            <span class="fa-prof-vid-name"><%= clipNameFromPath(clip.output_video || clip.input_video) %></span>
                                                                            <span class="fa-prof-vid-size">
                                                                                <%
                                                                                var outSize = clip.output_size_mb;
                                                                                var inSize = clip.input_size_mb;
                                                                                var size = (outSize != null && isFinite(outSize)) ? outSize : ((inSize != null && isFinite(inSize)) ? inSize : null);
                                                                                %>
                                                                                <%= size != null ? (Number(size).toFixed(1) + " MB") : "—" %>
                                                                            </span>
                                                                        </span>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <% if (clip.created_at) { %>
                                                                        <time datetime="<%= new Date(clip.created_at).toISOString() %>">
                                                                            <%= new Date(clip.created_at).toLocaleDateString("vi-VN") %>
                                                                        </time>
                                                                    <% } else { %>
                                                                        —
                                                                    <% } %>
                                                                </td>
                                                                <td>
                                                                    <div class="fa-prof-actions">
                                                                        <a href="/detail-match?videoId=<%= clip.id %>" class="fa-prof-act fa-prof-act--view" aria-label="View">
                                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                                                <circle cx="12" cy="12" r="3" />
                                                                            </svg>
                                                                            View
                                                                        </a>
                                                                        <a href="/videos/<%= clip.id %>/download" class="fa-prof-act fa-prof-act--dl" aria-label="Download">
                                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                                                <polyline points="7 10 12 15 17 10" />
                                                                                <line x1="12" y1="15" x2="12" y2="3" />
                                                                            </svg>
                                                                            Download
                                                                        </a>
                                                                        <button type="button" class="fa-prof-act fa-prof-act--del" aria-label="Delete" data-fa-prof-delete data-video-id="<%= clip.id %>">
                                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                <polyline points="3 6 5 6 21 6" />
                                                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                                                            </svg>
                                                                            Delete
                                                                        </button>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr data-fa-prof-date="0">
                                                            <td colspan="7" class="admin-table-empty">No analyzed clips yet.</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>

                                        <footer class="fa-prof-pagination" aria-label="Pagination">
                                            <span class="fa-prof-pagination__info" id="fa-prof-page-info">Showing 0–0 of 0 results</span>
                                            <nav class="fa-prof-pagination__nav" id="fa-prof-page-nav" aria-label="Page"></nav>
                                            <div class="fa-prof-rows">
                                                <label for="fa-prof-rows-select">Rows per page:</label>
                                                <select id="fa-prof-rows-select" class="fa-prof-rows__select"
                                                    aria-label="Rows per page">
                                                    <option value="10">10</option>
                                                    <option value="25">25</option>
                                                    <option value="50">50</option>
                                                </select>
                                            </div>
                                        </footer>
                                    </main>
                                </div>
            </div>
        </div>

        <div class="fa-prof-modal" id="fa-prof-update-modal" hidden aria-hidden="true">
            <div class="fa-prof-modal__backdrop" data-fa-prof-close-modal tabindex="-1"></div>
            <div class="fa-prof-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="fa-prof-modal-title"
                tabindex="-1">
                <div class="fa-prof-modal__head">
                    <h2 id="fa-prof-modal-title" class="fa-prof-modal__title">Update profile</h2>
                    <button type="button" class="fa-prof-modal__close" data-fa-prof-close-modal
                        aria-label="Close">&times;</button>
                </div>
                <form class="fa-prof-modal__form" id="fa-prof-update-form" action="/profile" method="post"
                    enctype="multipart/form-data" novalidate>
                    <p class="fa-prof-modal__hint">Only fill in the fields you want to change — all fields are optional.
                    </p>
                    <div class="fa-field">
                        <label class="fa-field__label" for="avatarFile">Avatar</label>
                        <input class="form-control fa-field__input fa-prof-modal__file" type="file" id="avatarFile"
                            name="avatar" accept="image/jpeg,image/png,.jpg,.jpeg,.png">
                        <img style="max-height: 250px; display: none;" alt="avatar preview" id="avatarPreview" />
                    </div>
                    <div class="fa-field">
                        <label class="fa-field__label" for="fa-prof-up-name">Name</label>
                        <input class="fa-field__input" type="text" id="fa-prof-up-name" name="name"
                            placeholder="Full name" autocomplete="name"
                            value="<%= profileUser && profileUser.name ? profileUser.name : '' %>">
                    </div>
                    <div class="fa-field">
                        <label class="fa-field__label" for="fa-prof-up-username">Username</label>
                        <input class="fa-field__input" type="text" id="fa-prof-up-username" name="username"
                            placeholder="username" autocomplete="username" required
                            value="<%= profileUser && profileUser.username ? profileUser.username : '' %>">
                    </div>
                    <div class="fa-field">
                        <label class="fa-field__label" for="fa-prof-up-oldpw">Old password</label>
                        <input class="fa-field__input" type="password" id="fa-prof-up-oldpw" name="oldPassword"
                            placeholder="••••••••" autocomplete="current-password">
                    </div>
                    <div class="fa-field">
                        <label class="fa-field__label" for="fa-prof-up-newpw">New password</label>
                        <input class="fa-field__input" type="password" id="fa-prof-up-newpw" name="newPassword"
                            placeholder="••••••••" autocomplete="new-password">
                    </div>
                    <button type="submit"
                        class="fa-btn-primary fa-btn-primary--block fa-prof-modal__submit">Update</button>
                </form>
            </div>
        </div>

        <script src="/javascripts/main.js" defer></script>
</body>

</html>