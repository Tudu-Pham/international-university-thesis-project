<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Match detail — Football Analytics</title>
    <link rel="icon" type="image/png" href="/images/logo.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script type="application/json"
        id="fa-dm-match-data"><%- JSON.stringify({ teamAPossession: typeof possessionTeamA === 'number' ? possessionTeamA : 0 }) %></script>
</head>

<body class="page-fa-analyze page-fa-detail-match">
    <div class="fa-analyze__bg" aria-hidden="true"></div>
    <div class="fa-analyze__veil" aria-hidden="true"></div>

    <div class="fa-shell">
        <aside class="fa-sidebar fa-sidebar--detail-back" aria-label="Match navigation">
            <a class="fa-sidebar__link fa-sidebar__link--back" href="/football-analytics" title="Back">
                <svg class="fa-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    aria-hidden="true">
                    <line x1="19" y1="12" x2="5" y2="12" />
                    <polyline points="12 19 5 12 12 5" />
                </svg>
                <span class="fa-sidebar__back-label">Back</span>
            </a>
        </aside>

        <div class="fa-workspace">
            <header class="fa-topbar" role="banner">
                <div class="fa-topbar__brand">
                    <img src="/images/logo.png" alt="" class="fa-topbar__logo" width="44" height="44">
                    <a href="/" class="simple-link">
                        <div class="fa-topbar__brand-text">
                            <span class="fa-topbar__brand-football">FOOTBALL</span>
                            <span class="fa-topbar__brand-analytics">ANALYTICS</span>
                        </div>
                    </a>
                </div>
                <div class="fa-topbar__user">
                    <div class="fa-user-chip">
                        <span class="fa-user-chip__avatar" aria-hidden="true">
                            <img src="<%= currentUser && currentUser.avatar ? currentUser.avatar : '/images/default_avatar.jpg' %>" alt="">
                        </span>
                        <span class="fa-user-chip__name"><%= currentUser && currentUser.name ? currentUser.name : '' %></span>
                    </div>
                    <a href="/logout" class="fa-btn-logout fa-btn-logout--link">Log out</a>
                </div>
            </header>

            <main class="fa-dm-main">
                <div class="fa-dm-grid">
                    <section class="fa-dm-video-section" aria-label="Match video">
                        <div class="fa-dm-video-card">
                            <video id="match-video" class="fa-dm-video" controls playsinline webkit-playsinline preload="metadata"
                                poster="/images/theme.png" src="<%= typeof matchVideoSrc === 'string' ? matchVideoSrc : '' %>">
                                Your browser does not support the video tag.
                            </video>
                        </div>
                    </section>

                    <aside class="fa-dm-rail" aria-label="Match insights">
                        <div class="fa-dm-card fa-dm-card--possession">
                            <h2 class="fa-dm-card__title">Ball Possession</h2>
                            <div class="fa-dm-pie-wrap">
                                <div class="fa-dm-pie fa-dm-pie--solid" id="fa-dm-pie" role="img"
                                    aria-label="Ball possession distribution">
                                    <div class="fa-dm-pie__conic" id="fa-dm-pie-conic"></div>
                                </div>
                            </div>
                            <div class="fa-dm-pie-legend" id="fa-dm-pie-legend">
                                <span class="fa-dm-pie-legend__item">
                                    <span class="fa-dm-pie-legend__dot fa-dm-pie-legend__dot--a"
                                        aria-hidden="true"></span>
                                    <span class="fa-dm-pie-legend__label"><%= typeof teamAName === 'string' ? teamAName : 'Team A' %></span>
                                    <span class="fa-dm-pie-legend__val" data-fa-dm-legend-a>0%</span>
                                </span>
                                <span class="fa-dm-pie-legend__item">
                                    <span class="fa-dm-pie-legend__dot fa-dm-pie-legend__dot--b"
                                        aria-hidden="true"></span>
                                    <span class="fa-dm-pie-legend__label"><%= typeof teamBName === 'string' ? teamBName : 'Team B' %></span>
                                    <span class="fa-dm-pie-legend__val" data-fa-dm-legend-b>0%</span>
                                </span>
                            </div>
                        </div>

                        <div class="fa-dm-card fa-dm-card--minimap">
                            <h2 class="fa-dm-card__title">Mini-map</h2>
                            <div class="fa-dm-minimap-frame">
                                <video id="minimap-video" class="fa-dm-video" playsinline webkit-playsinline preload="metadata"
                                    src="<%= typeof matchVideoSrc === 'string' ? matchVideoSrc : '' %>">
                                    Your browser does not support the video tag.
                                </video>
                            </div>
                        </div>
                    </aside>
                </div>

                <section class="fa-dm-stats" aria-labelledby="fa-dm-stats-heading">
                    <h2 id="fa-dm-stats-heading" class="fa-dm-stats__title">Player Statistics</h2>
                    <div class="fa-dm-table-wrap">
                        <table class="fa-dm-table">
                            <thead>
                                <tr>
                                    <th scope="col">Shirt Number</th>
                                    <th scope="col">Team</th>
                                    <th scope="col">Player Name</th>
                                    <th scope="col">Average Speed</th>
                                    <th scope="col">Ball Possession</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof players !== 'undefined' && players && players.length) { %>
                                    <% players.forEach(function(p) { %>
                                        <tr>
                                            <td><%= p.shirt_number != null ? p.shirt_number : "—" %></td>
                                            <td>
                                                <% var isA = typeof teamAName === 'string' && p.team === teamAName; %>
                                                <span class="fa-dm-table__team <%= isA ? 'fa-dm-table__team--a' : 'fa-dm-table__team--b' %>"><%= p.team != null ? p.team : '—' %></span>
                                            </td>
                                            <td><%= p.player_name != null ? p.player_name : "—" %></td>
                                            <td><%= p.avg_speed != null ? p.avg_speed : "—" %></td>
                                            <td>
                                                <div class="fa-dm-bar-cell">
                                                    <span class="fa-dm-bar-cell__text"><%= p.possession_percent != null ? p.possession_percent : 0 %>%</span>
                                                    <span class="fa-dm-bar" role="presentation"><span class="fa-dm-bar__fill"
                                                            style="width:<%= p.possession_percent != null ? p.possession_percent : 0 %>%"></span></span>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="admin-table-empty">No player statistics yet.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>