<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Details</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet" />

    <link rel="icon" type="image/png" href="/images/logo.ico" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="admin-page admin-view-page">
    <div class="admin-bg" aria-hidden="true"></div>
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-sidebar__brand">
                <div class="admin-brand-mark" aria-hidden="true">
                    <img src="/images/logo.png" alt="" />
                </div>
                <div class="admin-brand-text">
                    <div class="admin-brand-title">FOOTBALL</div>
                    <div class="admin-brand-subtitle">ANALYTICS</div>
                </div>
            </div>

            <nav class="admin-nav" aria-label="Admin navigation">
                <a class="admin-nav__item" href="/admin">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M3 12l2-2 4 4 8-8 4 4-2 2-6-6-8 8z"></path>
                        </svg>
                    </span>
                    Dashboard
                </a>
                <a class="admin-nav__item is-active" href="/admin">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M20 8v6"></path>
                            <path d="M23 11h-6"></path>
                        </svg>
                    </span>
                    Users
                </a>
                <a class="admin-nav__item" href="/matches">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M8 7h12"></path>
                            <path d="M8 12h12"></path>
                            <path d="M8 17h12"></path>
                            <path d="M4 7h.01"></path>
                            <path d="M4 12h.01"></path>
                            <path d="M4 17h.01"></path>
                        </svg>
                    </span>
                    Matches
                </a>
            </nav>

            <div class="admin-sidebar__footer">
                <div class="admin-profile">
                    <div class="admin-profile__avatar" aria-hidden="true">
                        <img src="/images/logo.png" alt="" />
                    </div>
                    <div class="admin-profile__meta">
                        <div class="admin-profile__name">
                            <%= user[0].username %>
                        </div>
                        <div class="admin-profile__role">Admin</div>
                    </div>
                </div>

                <a class="admin-logout" href="/signin">
                    <span class="admin-logout__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M10 17l5-5-5-5"></path>
                            <path d="M15 12H3"></path>
                            <path d="M21 3v18"></path>
                        </svg>
                    </span>
                    Logout
                </a>
            </div>
        </aside>

        <main class="admin-main admin-view-main">
            <header class="admin-header">
                <div class="admin-breadcrumbs">
                    Dashboard <span class="admin-breadcrumbs__sep">/</span> User Management
                </div>
            </header>

            <section class="admin-view-content">
                <article class="admin-view-profile-card">
                    <div class="admin-view-profile__left">
                        <div class="admin-view-profile__avatar">
                            <img src="/images/logo.png" alt="User avatar" />
                        </div>
                        <div class="admin-view-profile__meta">
                            <h1 class="admin-view-profile__name">
                                <%= user[0].name %>
                            </h1>
                            <p class="admin-view-profile__line"><span>User:</span>
                                <%= user[0].username %>
                            </p>
                            <p class="admin-view-profile__line"><span>Email:</span>
                                <%= user[0].email %>
                            </p>
                            <p class="admin-view-profile__line"><span>Member</span>since June 2026</p>
                        </div>
                    </div>
                    <button class="admin-btn admin-btn--primary admin-view-profile__edit" type="button">
                        <span aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                            </svg>
                        </span>
                        Edit Profile
                    </button>
                </article>

                <section class="admin-view-table-card">
                    <header class="admin-view-table__header">
                        <h2>Uploaded Matches</h2>
                    </header>

                    <div class="admin-table-wrap">
                        <table class="admin-table admin-view-table" aria-label="Uploaded matches table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Team A</th>
                                    <th>Team B</th>
                                    <th>Video Input</th>
                                    <th>Video Output</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td>Manchester United</td>
                                    <td>Chelsea</td>
                                    <td>match1.mp4</td>
                                    <td>match1_output.mp4</td>
                                    <td>
                                        <button type="button"
                                            class="admin-action admin-action--delete admin-view-delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>2</td>
                                    <td>Liverpool</td>
                                    <td>Arsenal</td>
                                    <td>liverpool_vs_arsenal.mp4</td>
                                    <td>liverpool_output.mp4</td>
                                    <td>
                                        <button type="button"
                                            class="admin-action admin-action--delete admin-view-delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>3</td>
                                    <td>France</td>
                                    <td>Brazil</td>
                                    <td>france_vs_brazil.mp4</td>
                                    <td>france_output.mp4</td>
                                    <td>
                                        <button type="button"
                                            class="admin-action admin-action--delete admin-view-delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </section>
        </main>
    </div>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>