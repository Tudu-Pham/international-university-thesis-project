<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Uploaded Matches</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet" />

    <link rel="icon" type="image/png" href="/images/logo.ico" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="admin-page admin-matches-page">
    <div class="admin-bg" aria-hidden="true"></div>
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-sidebar__brand">
                <div class="admin-brand-mark" aria-hidden="true">
                    <img src="/images/logo.png" alt="" />
                </div>
                <a href="/" class="simple-link">
                    <div class="admin-brand-text">
                        <div class="admin-brand-title">FOOTBALL</div>
                        <div class="admin-brand-subtitle">ANALYTICS</div>
                    </div>
                </a>
            </div>

            <nav class="admin-nav" aria-label="Admin navigation">
                <a class="admin-nav__item" href="/admin">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M3 12l2-2 4 4 8-8 4 4-2 2-6-6-8 8z"></path>
                        </svg>
                    </span>
                    Dashboard
                </a>
                <a class="admin-nav__item" href="#" data-users-nav-popup="true">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M20 8v6"></path>
                            <path d="M23 11h-6"></path>
                        </svg>
                    </span>
                    Users
                </a>
                <a class="admin-nav__item is-active" href="#">
                    <span class="admin-nav__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M8 7h12"></path>
                            <path d="M8 12h12"></path>
                            <path d="M8 17h12"></path>
                            <path d="M4 7h.01"></path>
                            <path d="M4 12h.01"></path>
                            <path d="M4 17h.01"></path>
                        </svg>
                    </span>
                    Matches
                </a>
            </nav>

            <div class="admin-sidebar__footer">
                <div class="admin-profile">
                    <div class="admin-profile__avatar" aria-hidden="true">
                        <img src="<%= currentUser && currentUser.avatar ? currentUser.avatar : '/images/default_avatar.jpg' %>" alt="" />
                    </div>
                    <div class="admin-profile__meta">
                        <div class="admin-profile__name"><%= currentUser && currentUser.name ? currentUser.name : '' %></div>
                        <div class="admin-profile__role">Admin</div>
                    </div>
                </div>

                <a class="admin-logout" href="/logout">
                    <span class="admin-logout__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M10 17l5-5-5-5"></path>
                            <path d="M15 12H3"></path>
                            <path d="M21 3v18"></path>
                        </svg>
                    </span>
                    Logout
                </a>
            </div>
        </aside>

        <main class="admin-main admin-matches-main">
            <header class="admin-header">
                <div class="admin-breadcrumbs">
                    Dashboard <span class="admin-breadcrumbs__sep">/</span> Matches
                </div>
            </header>

            <section class="admin-matches-content">
                <h1 class="admin-matches-title">Uploaded Matches</h1>

                <section class="admin-matches-table-card">
                    <div class="admin-table-wrap">
                        <table class="admin-table admin-matches-table" aria-label="Uploaded matches table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Team A</th>
                                    <th>Team B</th>
                                    <th>Video Input</th>
                                    <th>Video Output</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="admin-matches-tbody" data-admin-paginate>
                                <%
                                function clipNameFromPath(p) {
                                    if (!p) return "—";
                                    var s = String(p);
                                    s = s.split("?")[0].split("#")[0];
                                    s = s.replace(/\\/g, "/");
                                    var parts = s.split("/");
                                    return parts[parts.length - 1] || "—";
                                }
                                %>

                                <% if (typeof videos !== 'undefined' && videos && videos.length) { %>
                                    <% videos.forEach(function(v) { %>
                                        <tr data-admin-date="<%= v.created_at ? new Date(v.created_at).getTime() : 0 %>">
                                            <td><%= v.id %></td>
                                            <td><%= v.username ? v.username : '—' %></td>
                                            <td><%= v.team_a ? v.team_a : '—' %></td>
                                            <td><%= v.team_b ? v.team_b : '—' %></td>
                                            <td><%= clipNameFromPath(v.input_video) %></td>
                                            <td><%= clipNameFromPath(v.output_video || v.input_video) %></td>
                                            <td class="admin-table-actions">
                                                <a class="admin-action admin-action--view simple-link" href="/detail-match?videoId=<%= v.id %>">View</a>
                                                <a class="admin-action admin-action--view simple-link" href="/admin/videos/<%= v.id %>/download">Download</a>
                                                <button type="button" class="admin-action admin-action--delete" data-admin-video-delete data-video-id="<%= v.id %>">Delete</button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="admin-table-empty">No uploaded matches yet.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                        <div class="admin-pagination" aria-label="Pagination" data-admin-pagination>
                            <span class="admin-page-info" data-admin-page-info>Showing 0–0 of 0</span>
                            <div class="admin-page-nav" data-admin-page-nav></div>
                        </div>

                    </div>
                </section>
            </section>
        </main>
    </div>

    <script src="/javascripts/main.js" defer></script>
</body>

</html>