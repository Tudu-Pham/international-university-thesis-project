{
  "name": "thesis-web",
  "version": "1.0.0",
  "description": "web for thesis project",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon",
    "dev": "nodemon",
    "start:debug": "nodemon --inspect=9229 -e ts,tsx --exec node -r ts-node/register -r tsconfig-paths/register ./src/app.ts"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "node_modules"
    ],
    "exec": "ts-node -r tsconfig-paths/register ./src/app.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tudu-Pham/football-analytics-thesis-project.git"
  },
  "author": "Pham Trung Dung - ITITIU21007",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Tudu-Pham/football-analytics-thesis-project/issues"
  },
  "homepage": "https://github.com/Tudu-Pham/football-analytics-thesis-project#readme",
  "dependencies": {
    "@prisma/client": "6.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "16.4.7",
    "ejs": "3.1.10",
    "express": "5.0.1",
    "express-session": "^1.19.0",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.12.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.7",
    "@types/nodemailer": "^8.0.0",
    "nodemon": "3.1.9",
    "prisma": "6.3.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3"
  }
}
